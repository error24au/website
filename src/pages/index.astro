<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Error 24 — Software Studio</title>
        <meta
            name="description"
            content="Error 24 is an independent software studio building tools for creative communities."
        />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=Outfit:wght@300;400;500;600&display=swap"
            rel="stylesheet"
        />
        <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
    </head>
    <body
        class="min-h-screen bg-[#0d1117] text-[#e2e7eb] antialiased text-[17px]"
    >
        <nav class="border-b border-white/10 py-5">
            <div class="mx-auto flex w-full max-w-[720px] items-center justify-between px-6">
                <div class="flex items-center gap-[0.65rem]">
                    <span
                        class="[font-family:'JetBrains_Mono','SF_Mono',monospace] text-[0.85rem] font-semibold tracking-tight text-[#e2e7eb]"
                        >error</span
                    >
                    <div
                        class="flex h-8 w-8 items-center justify-center rounded-md border-2 border-[#25a9b2] [font-family:'JetBrains_Mono','SF_Mono',monospace] text-[0.8rem] font-bold text-[#40c5cc]"
                    >
                        24
                    </div>
                </div>
            </div>
        </nav>

        <main class="flex-1">
            <section class="py-16 sm:py-24 sm:pb-16">
                <div class="mx-auto w-full max-w-[720px] px-6">
                    <h1
                        class="animate-fade-in-up opacity-0 [animation-delay:0.05s] text-[clamp(2rem,4vw,2.75rem)] font-semibold leading-[1.2] tracking-[-0.03em] text-[#f8fafb]"
                    >
                        Tools to help creative people<br /><span class="text-[#40c5cc]"
                            >get stuff done.</span>
                    </h1>
                </div>
            </section>

            <section class="py-12 sm:py-16">
                <div class="mx-auto w-full max-w-[720px] px-6">
                    <div
                        class="mb-10 animate-fade-in-up opacity-0 [animation-delay:0.2s] [font-family:'JetBrains_Mono','SF_Mono',monospace] text-[0.8rem] font-medium uppercase tracking-[0.15em] text-[#25a9b2]"
                    >
                        // about
                    </div>
                    <p
                        class="mb-4 animate-fade-in-up opacity-0 [animation-delay:0.3s] text-[0.95rem] font-light leading-[1.75] text-[#94a3b0]"
                    >
                        Error 24 is a two-person software studio. We focus on
                        building tools that solve real operational problems for
                        communities that are typically underserved by software.
                    </p>
                    <p
                        class="mb-4 animate-fade-in-up opacity-0 [animation-delay:0.3s] text-[0.95rem] font-light leading-[1.75] text-[#94a3b0]"
                    >
                        At the moment, we're building <span class="text-white font-medium">Stagely</span>, a production management for performing arts companies.
                        Scheduling, attendance, communication, and file
                        sharing - built for the way theatre actually works.
                    </p>
                    <p
                        class="animate-fade-in-up opacity-0 [animation-delay:0.4s] text-[0.95rem] font-light leading-[1.75] text-[#94a3b0]"
                    >
                        Based in Warrnambool, Australia.
                    </p>
                </div>
            </section>

            <section class="py-12 sm:py-16">
                <div class="mx-auto w-full max-w-[720px] px-6">
                    <div
                        class="mb-10 animate-fade-in-up opacity-0 [animation-delay:0.2s] [font-family:'JetBrains_Mono','SF_Mono',monospace] text-[0.8rem] font-medium uppercase tracking-[0.15em] text-[#25a9b2]"
                    >
                        // contact
                    </div>
                    <form
                        id="contact-form"
                        class="flex flex-col gap-4 animate-fade-in-up opacity-0 [animation-delay:0.3s]"
                        method="POST"
                        action="/api/contact"
                    >
                        <input
                            class="rounded-md border border-white/10 bg-white/[0.015] px-4 py-3 text-[0.95rem] text-[#e2e7eb] placeholder:text-[#6b7b8a] outline-none transition-colors focus:border-[#25a9b2]/60"
                            name="name"
                            required
                            placeholder="Name"
                        />
                        <input
                            class="rounded-md border border-white/10 bg-white/[0.015] px-4 py-3 text-[0.95rem] text-[#e2e7eb] placeholder:text-[#6b7b8a] outline-none transition-colors focus:border-[#25a9b2]/60"
                            name="email"
                            type="email"
                            required
                            placeholder="Email"
                        />
                        <textarea
                            class="min-h-[140px] rounded-md border border-white/10 bg-white/[0.015] px-4 py-3 text-[0.95rem] text-[#e2e7eb] placeholder:text-[#6b7b8a] outline-none transition-colors focus:border-[#25a9b2]/60"
                            name="message"
                            required
                            placeholder="Message"
                        ></textarea>
                        <div id="cf-turnstile" class="cf-turnstile" data-sitekey="0x4AAAAAACnjR-eMgdcDSOzE" data-theme="dark"></div>
                        <input type="hidden" name="cf-turnstile-response" id="cf-turnstile-response" />
                        <button
                            id="contact-submit"
                            class="inline-flex w-fit items-center justify-center rounded-md border border-[#25a9b2]/50 bg-[#25a9b2]/[0.12] px-5 py-2.5 [font-family:'JetBrains_Mono','SF_Mono',monospace] text-[0.75rem] uppercase tracking-[0.1em] text-[#40c5cc] transition-colors hover:bg-[#25a9b2]/20"
                            type="submit"
                        >
                            Send
                        </button>
                        <p
                            id="contact-feedback"
                            class="min-h-6 text-sm"
                            aria-live="polite"
                        ></p>
                    </form>
                </div>
            </section>
        </main>

        <footer class="mt-auto border-t border-white/10 py-10">
            <div class="mx-auto flex w-full max-w-[720px] flex-col gap-3 px-6">
                <div class="flex flex-wrap items-center justify-between gap-2">
                    <span
                        class="[font-family:'JetBrains_Mono','SF_Mono',monospace] text-[0.95rem] text-[#556270]"
                        >&copy; 2025 Error 24 Pty Ltd</span
                    >
                </div>
                <span
                    class="[font-family:'JetBrains_Mono','SF_Mono',monospace] text-[0.9rem] text-[#44505c]"
                    >ABN 14 694 990 424</span
                >
            </div>
        </footer>
        <script>
          const form = document.getElementById("contact-form") as HTMLFormElement;
          const msg = document.getElementById("contact-feedback");
          const turnstileResponse = document.getElementById("cf-turnstile-response") as HTMLInputElement;

          window.onTurnstileSuccess = (token: string) => {
            turnstileResponse.value = token;
          };

          form.addEventListener("submit", async (e) => {
            e.preventDefault();

            const res = await fetch(form.action, {
              method: "POST",
              body: new FormData(form),
            });

            const json = await res.json();
            msg.textContent = res.ok ? "Thanks, we'll get back to you soon!" : (json.error || "Sorry, failed to send. Try emailing us at: hello [at] error24.com.au");
            if (res.ok) form.reset();
          });
        </script>

    </body>
</html>
